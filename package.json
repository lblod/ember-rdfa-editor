{
  "private": true,
  "license": "MIT",
  "author": "redpencil.io",
  "scripts": {
    "build": "pnpm --filter !test-app build",
    "build:test-app": "pnpm --filter test-app build",
    "lint": "pnpm --filter '*' lint",
    "lint:fix": "pnpm --filter '*' lint:fix",
    "lint:types": "pnpm --filter '*' lint:types",
    "prepack": "pnpm build",
    "start": "pnpm build; concurrently 'pnpm:start:* {@}' --passthrough-arguments --restart-after 5000 --prefixColors auto",
    "start:addon": "pnpm --filter @lblod/ember-rdfa-editor start --no-watch.clearScreen",
    "start:test-app": "pnpm --filter test-app start",
    "test": "pnpm --filter '*' test",
    "test:ember": "pnpm --filter '*' test:ember",
    "test:quickstart": "cd quickstart && npm run setup && npm run ci && npm run teardown",
    "test:quickstart:setup": "cd quickstart && npm run setup",
    "format": "pnpm --filter '*' format",
    "say": "pnpm --filter @lblod/ember-rdfa-editor",
    "tapp": "pnpm --filter test-app",
    "release": "tsx scripts/release/run.mts",
    "dev-release": "tsx scripts/dev-release/run.mts",
    "dev-release:say": "tsx scripts/dev-release/run.mts ember-rdfa-editor",
    "dev-release:rr": "tsx scripts/dev-release/run.mts say-roadsign-regulation-plugin",
    "dev-release:ar": "tsx scripts/dev-release/run.mts say-ar-design-plugin",
    "doc": "pnpm run doc:generate && pnpm run doc:serve",
    "doc:generate": "pnpm say doc:generate",
    "doc:serve": "pnpm static-server ./packages/ember-rdfa-editor/docs"
  },
  "packageManager": "pnpm@11.4.0",
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@changesets/get-release-plan": "catalog:",
    "@manypkg/get-packages": "catalog:",
    "@types/git-url-parse": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "catalog:",
    "execa": "catalog:",
    "git-url-parse": "catalog:",
    "mdast-util-to-string": "catalog:",
    "octokit": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-ember-template-tag": "catalog:",
    "remark-parse": "catalog:",
    "remark-stringify": "catalog:",
    "static-server": "^2.2.1",
    "tsx": "catalog:",
    "unified": "catalog:"
  }
}
